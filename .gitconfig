[user]
	email = ichi.ttht.1@gmail.com
	name = ichi

[color]
	ui = auto
	diff = auto
	status = auto
	branch = auto
	interactive = auto
	autocrlf = true

[alias]
	ad = add
	br = branch
	ci = commit
	cm = commit
	ca = commit --amend -C HEAD
	ci = commit --interactive
	co = checkout
	lo = log --decorate=full
	lg = log --decorate=full --graph
	ls = log --decorate=full --name-status
	st = status
	mn = merge --no-ff
	wt = worktree
	cp = cherry-pick
	rb = rebase

[color "branch"]
       current = yellow reverse
       local = yellow
       remote = cyan

[core]
	editor = "emacs -nw"
	excludesfile = ~/.gitignore_global
#	pager = nkf -w | less -R
	pager = less -R
	filemode = false
	quotepath = false
	whitespace = cr-at-eol
	precomposeunicode = true
	autocrlf = false

[push]
	default = upstream

[pull]
	rebase = false
#	rebase = true

[pager]
	log  = (which diff-so-fancy > /dev/null && diff-so-fancy || which diff-highlight > /dev/null && diff-highlight || cat) | less
	show = (which diff-so-fancy > /dev/null && diff-so-fancy || which diff-highlight > /dev/null && diff-highlight || cat) | less
	diff = (which diff-so-fancy > /dev/null && diff-so-fancy || which diff-highlight > /dev/null && diff-highlight || cat) | less

[diff]
	compactionHeuristic = true
	tool = default-difftool

[difftool "default-difftool"]
	cmd = code --wait --diff $LOCAL $REMOTE

[interactive]
	diffFilter = diff-highlight

[merge]
	tool = p4merge

[mergetool]
  keepBackup = false

[mergetool "p4merge"]
  path = p4merge
  keepTemporaries = false
  trustExitCode = false

[diff]
	algorithm = histogram # default|patience|histogram
#  external = git-p4diff

#[branch]
#	mergeoptions = --no-ff

[rerere]
	enabled = true

[rebase]
	autosquash = true
[grep]
	lineNumber = true

[ghq]
root = ~/.ghq
[safe]
	directory = /quipper
